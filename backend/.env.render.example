# ─────────────────────────────────────────────────────────────────────────────
# VulnSploit — Render Environment Variables Reference
# ─────────────────────────────────────────────────────────────────────────────
# These are the env vars you need to set manually in the Render dashboard
# for vulnsploit-api and vulnsploit-celery services.
#
# Variables marked [AUTO] are set automatically by render.yaml.
# Variables marked [MANUAL] must be set by you in the Render dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# [AUTO] Generated by Render — do not set manually
SECRET_KEY=

# [AUTO] Set by render.yaml
DEBUG=False

# [AUTO] Set by render.yaml — add your frontend URL here
# Example: https://vulnsploit.vercel.app,https://vulnsploit.netlify.app
CORS_ALLOWED_ORIGINS=https://your-frontend-url.vercel.app

# [AUTO] Set by render.yaml from Render's PostgreSQL service
DB_ENGINE=django.db.backends.postgresql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# [AUTO] Set by render.yaml from Render's Redis service
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# [MANUAL] Get free key at https://aistudio.google.com/app/apikey
# Set this in Render dashboard under vulnsploit-api → Environment
GEMINI_API_KEY=

# [AUTO] Keep False on Render — SSL is terminated at the load balancer
SECURE_SSL_REDIRECT=False

# [OPTIONAL] Adjust rate limits for production traffic
SCAN_RATE_LIMIT=20/h
LOGIN_RATE_LIMIT=10/15m
